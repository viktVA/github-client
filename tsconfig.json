{
  "include": ["src"],
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@/*": ["*"],
      "@App": ["App/*"],
      "@components/*": ["components/*"],
      "@config/*": ["config/*"],
      "@styles/*": ["styles/*"],
      "@utils/*" : ["utils/*"],
      "@api/*": ["api/*"],
      "@assets/*": ["assets/*"],
      "@custom_types/*": ["custom_types/*"]
    }
  }
}
